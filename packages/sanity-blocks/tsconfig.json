{
  "extends": "@workspace/typescript-config/react-library.json",
  "compilerOptions": {
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    "paths": {
      "@workspace/sanity-blocks": ["./src/sanity-blocks.ts"],
      "@workspace/sanity-blocks/*": ["./src/*"]
    },
    "rootDir": "src",
    "types": ["node", "jest"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
